@inherits LayoutComponentBase
<MudRTLProvider RightToLeft="@_rightToLeft">
    <MudDialogProvider />
    <MudSnackbarProvider />
    <MudPopoverProvider />
    <MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />



    <MudLayout>
        <MudAppBar Elevation="0">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
            <MudSpacer />


            <AuthorizeView>
                <Authorized>
                    <MudMenu Icon="@Icons.Material.Outlined.PeopleAlt" Color="Color.Inherit" Direction="Direction.Bottom" OffsetY="true" Dense="true">



                        <MudMenuItem Href="/logout">
                            <MudIcon Color="Color.Inherit" Icon="@Icons.Material.Sharp.Logout" />
                            Logout
                        </MudMenuItem>

                    </MudMenu>
                </Authorized>

                <NotAuthorized>
                    <MudButton Href="/login"
                               EndIcon="@Icons.Material.Sharp.Person"
                               Color="Color.Inherit">
                    </MudButton>
                </NotAuthorized>

            </AuthorizeView>

            <MudToggleIconButton @bind-Toggled="@_isDarkMode"
                                 Icon="@Icons.Material.Filled.DarkMode" Color="@Color.Inherit" Title="DarkMode"
                                 ToggledIcon="@Icons.Material.Filled.LightMode" ToggledColor="@Color.Inherit" ToggledTitle="LightMode" />

            <MudToggleIconButton @bind-Toggled="@_rightToLeft"
                                 Icon="@Icons.Material.Filled.Language" Color="@Color.Inherit" Title="Language"
                                 ToggledIcon="@Icons.Material.Filled.Language" ToggledColor="@Color.Inherit" ToggledTitle="Language" />

        </MudAppBar>


        <MudDrawer @bind-Open="_drawerOpen" Elevation="1">
            <MudDrawerHeader>
                <MudNavLink Href="/" Match="NavLinkMatch.All">CMS Blazor</MudNavLink>
                @*<MudText Typo="Typo.h6">CMS Blazor</MudText>*@
            </MudDrawerHeader>
            <NavMenu />
        </MudDrawer>


        <MudMainContent>
            @Body
        </MudMainContent>


    </MudLayout>
</MudRTLProvider>



@code {

        private bool _rightToLeft = false;
        bool _drawerOpen = true;

        void DrawerToggle()
        {
            _drawerOpen = !_drawerOpen;
        }

        private MudTheme _theme = new();
        private bool _isDarkMode = true;
    }
