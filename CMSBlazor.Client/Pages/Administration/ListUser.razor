@page "/listusers"
@layout MainLayout
@attribute [Authorize]

@inject IDialogService Dialog


<PageTitle>Users</PageTitle>
<MudOverlay @bind-Visible="isVisible" DarkBackground="true" AutoClose="true">
    <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
</MudOverlay>
@{

    if (_SuperAdmin != null || _Admin != null)
    {
        <MudContainer Style="padding-top:inherit;" MaxWidth="MaxWidth.Large">

            <MudGrid>
                <MudItem xs="12" sm="12">
                    <MudPaper Class="pa-4 mud-theme-primary">
                        <MudText Align="Align.Center" Typo="Typo.h4">Users</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>


            <MudContainer Style="padding-top:10px;" MaxWidth="MaxWidth.Large">



                <MudGrid>
                    <MudItem xs="12" sm="12" md="12">


                        @if (Users == null)
                        {
                            <MudPaper Class="pa-4 ma-2" Elevation="0">
                                <MudText Typo="Typo.h5">Not Found Item</MudText>
                            </MudPaper>
                        }
                        else
                        {

                            <MudDataGrid Filterable="true" QuickFilter="@_quickFilter" Bordered="true"
                                         Outlined="true" T="Users" Items="@Users" SortMode="@_sortMode">

                                <ToolBarContent>
                                    <MudSpacer />
                                    <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                                </ToolBarContent>


                                <Columns>
                                    <PropertyColumn Property="x => x!.UserName" Title="User Name" />



                                    <TemplateColumn CellClass="d-flex justify-end">
                                        <CellTemplate>
                                            <MudStack Row>
                                                <MudIconButton Disabled="@_policyEdit" OnClick="@((e) => OpenDialogEdite(@context.Item!))" Icon="@Icons.Material.Filled.Edit" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Medium" />
                                                <MudIconButton Disabled="@_policyDelete" OnClick="@((e) => OpenDialogDelete(@context.Item!))" Icon="@Icons.Material.Filled.Delete" Variant="Variant.Outlined" Color="Color.Error" Size="Size.Medium" />

                                            </MudStack>
                                        </CellTemplate>
                                    </TemplateColumn>




                                </Columns>

                                <PagerContent>
                                    <MudDataGridPager T="Users" />
                                </PagerContent>

                            </MudDataGrid>

                        }
                    </MudItem>

                </MudGrid>





            </MudContainer>

        </MudContainer>
    }
}




